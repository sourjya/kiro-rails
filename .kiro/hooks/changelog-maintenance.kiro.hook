{
  "enabled": true,
  "name": "Changelog Maintenance",
  "description": "Pre-commit: drafts changelog entry from git log (grouped by type), then asks agent to refine and verify rolling archive.",
  "version": "3.0.0",
  "when": {
    "type": "beforeCommit"
  },
  "then": {
    "type": "runCommand",
    "command": "bash scripts/changelog-draft.sh",
    "timeout": 15
  }
}
